# owner: ente-io
# repo: ente
# path: server/quickstart.sh
# commit-hash: 45f639f941b9aa53d301343d0f34227b60cbce6e

services:
  museum:
    image: ghcr.io/ente-io/server:latest@sha256:c56831e83306988b2f5ee30eee20194d6b8f848a9cc4f4afa75931722ac1086b
    container_name: "{{ services.ente_api.container_name }}"
    restart: always
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - default
      - caddy
    volumes:
      - "{{ ente_auth_service_dir }}/museum.yml:/museum.yaml:ro"
      - "{{ ente_auth_data_dir }}/data:/data:ro"
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:8080/ping"]
      interval: 60s
      timeout: 5s
      retries: 3
      start_period: 120s

  web:
    image: ghcr.io/ente-io/web:latest@sha256:94d76dae2ec6e767a86fa93da4c23243cd93f27295e82c51205bc137a4204dab
    container_name: "{{ services.ente_auth.container_name }}"
    restart: always
    networks:
      - default
      - caddy
    environment:
      ENTE_API_ORIGIN: "https://{{ services.ente_api.domain }}"

  postgres:
    image: postgres:15@sha256:3b0d656f5fff31c7d8a64f500a703dcf3f35e98ce78f602831a73059a5e6a012
    container_name: ente-postgres
    restart: always
    environment:
      POSTGRES_USER: "{{ ente_db_user }}"
      POSTGRES_PASSWORD: "{{ ente_db_password }}"
      POSTGRES_DB: "{{ ente_db_name }}"
    healthcheck:
      test: pg_isready -q -d {{ ente_db_name }} -U {{ ente_db_user }}
      start_period: 40s
      start_interval: 1s
    volumes:
      - "{{ ente_auth_data_dir }}/db:/var/lib/postgresql/data"

networks:
  caddy:
    external: true
