services:
  grocy:
    image: linuxserver/grocy:4.6.0@sha256:4298d77e169980ea4d6c86fbd0eccd97752050a9c7d5262432bda6553b3d513b
    container_name: "{{ services.grocy.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ grocy_data_dir }}/config:/config"

networks:
  caddy:
    external: true
