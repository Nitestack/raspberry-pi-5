services:
  grocy:
    image: linuxserver/grocy:4.6.0@sha256:53084bab56979a739ff936fc6857cc6cf99d30a689f6426ca159ea70236aca10
    container_name: "{{ services.grocy.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ grocy_data_dir }}/config:/config"

networks:
  caddy:
    external: true
