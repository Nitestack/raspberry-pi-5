services:
  grocy:
    image: linuxserver/grocy:4.6.0@sha256:ab39f3aeee92e121deafdd08966020dd05e3ed1dd323bab9e22988bd6d354572
    container_name: "{{ services.grocy.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ grocy_data_dir }}/config:/config"

networks:
  caddy:
    external: true
