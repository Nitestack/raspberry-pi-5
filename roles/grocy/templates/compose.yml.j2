services:
  grocy:
    image: linuxserver/grocy:4.6.0@sha256:a0890ba405a7f7b6eedf9eea756ab0bdb1fb38a06ab77d4c9ccd9418f468bbf5
    container_name: "{{ services.grocy.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ grocy_data_dir }}/config:/config"

networks:
  caddy:
    external: true
