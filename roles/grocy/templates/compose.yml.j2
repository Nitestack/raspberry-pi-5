services:
  grocy:
    image: linuxserver/grocy:4.6.0@sha256:78605883f916fd7d872d5b4037a829ae6ad14778e36984e19dfc496d023fb156
    container_name: "{{ services.grocy.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ grocy_data_dir }}/config:/config"

networks:
  caddy:
    external: true
