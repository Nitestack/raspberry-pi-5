services:
  grocy:
    image: linuxserver/grocy:4.6.0@sha256:20aaee6b741178035a0c538c87917a8d72113ce2686368183a28f38e823f785c
    container_name: "{{ services.grocy.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ grocy_data_dir }}/config:/config"

networks:
  caddy:
    external: true
