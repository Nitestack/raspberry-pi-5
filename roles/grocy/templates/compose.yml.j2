services:
  grocy:
    image: linuxserver/grocy:4.6.0@sha256:e84bfdb1de28a664e6f7b38f78551bd17a3e3ade4fdb0b9f6da4b0fbb306a7a8
    container_name: "{{ services.grocy.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ grocy_data_dir }}/config:/config"

networks:
  caddy:
    external: true
