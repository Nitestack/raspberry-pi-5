(cloudflare) {
  tls {
    dns cloudflare {env.CLOUDFLARE_API_TOKEN}
  }
}

*.{{ domain }} {
	import cloudflare

	{% for name, service in services.items() %}
	{% if service.enabled and service.domain is defined and service.domain == domain %}
	@www host www.{{ domain }}

	redir @www {scheme}://{{ domain }}/{uri} permanent

	{% endif %}
	{% endfor %}

	{% for name, service in services.items() %}
	{% if service.enabled
		and service.domain is defined
		and service.domain != domain
		and (service.port is defined or name == "adventure_log")
  %}
	@{{ name }} host {{ service.domain }}

	handle @{{ name }} {
	{% if name == "adventure_log" %}
		@frontend {
			not path /media* /admin* /static* /accounts*
		}
		reverse_proxy @frontend {{ service.container_names.frontend }}:{{ service.ports.frontend }}
		reverse_proxy {{ service.container_names.backend }}:{{ service.ports.backend }}
	{% elif name == "beszel" %}
		request_body {
			max_size 10MB
		}
		reverse_proxy {{ service.container_name }}:{{ service.port }} {
			transport http {
				read_timeout 360s
			}
		}
	{% elif name == "nextcloud" %}
		header Strict-Transport-Security max-age=31536000;
		reverse_proxy {{ service.container_name }}:{{ service.port }}
	{% elif name == "nextcloud_aio" %}
		reverse_proxy {{ service.container_name }}:{{ service.port }} {
			transport http {
				tls_insecure_skip_verify
			}
		}
	{% elif name == "sparky_fitness" %}
		header X-Content-Type-Options "nosniff"
		encode zstd gzip

		reverse_proxy {{ service.container_name }}:{{ service.port }} {
			# Grab the real IP from Cloudflare's special header and pass it to the app
			header_up X-Real-IP {http.request.header.Cf-Connecting-Ip}
			header_up X-Forwarded-For {http.request.header.Cf-Connecting-Ip}

			# CRITICAL FOR PROXY TUNNELS: Tell Better Auth exactly what domain this is coming from
			header_up Host {host}
			header_up X-Forwarded-Host {host}

			# Tell the app that the external connection is secure
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Ssl on
		}
	{% elif name == "vaultwarden" %}
		encode zstd gzip
		reverse_proxy {{ service.container_name }}:{{ service.port }} {
			header_up X-Real-IP {remote_host}
		}
	{% elif name == "wger" %}
		encode

		reverse_proxy {{ service.container_name }}:{{ service.port }} {
			header_up X-Real-IP {remote_host}
		}

		handle /static/* {
			root * /srv/wger
			file_server
		}

		handle /media/* {
			root * /srv/wger
			file_server
		}
	{% else %}
		reverse_proxy {{ service.container_name }}:{{ service.port }}
	{% endif %}
	}
	{% endif %}
	{% endfor %}

	handle {
		redir https://{{ domain }}{uri}
	}
}
