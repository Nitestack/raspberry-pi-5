services:
  caddy:
    image: caddybuilds/caddy-cloudflare:2.11.2@sha256:ca4994490b97c91d8cbce89ff9e3d3aa458e46fd489c43299bcca157a2ddd336
    container_name: caddy
    restart: always
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    cap_add:
      - NET_ADMIN
    networks:
      - caddy
    volumes:
      - "{{ caddy_service_dir }}/Caddyfile:/etc/caddy/Caddyfile:ro"
      - "{{ caddy_data_dir }}/data:/data"
      - "{{ caddy_data_dir }}/config:/config"

      # wger file server volumes
      - "{{ wger_data_dir }}/static:/srv/wger/static:ro"
      - "{{ wger_data_dir }}/media:/srv/wger/media:ro"
    environment:
      CLOUDFLARE_API_TOKEN: "{{ cloudflare_api_token }}"

networks:
  caddy:
    name: caddy
