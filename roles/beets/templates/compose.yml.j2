services:
  beets:
    image: linuxserver/beets:2.12.0@sha256:4fcf2a7ce3f3fe2d3f29abe088cf510813d31302f18c987c76f6cb02c0cecc11
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
