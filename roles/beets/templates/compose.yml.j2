services:
  beets:
    image: linuxserver/beets:2.11.0@sha256:14bfcf3993230b1ce416a54188e297fc3d20af249cabb5379ae5eb8c1528b7a9
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
