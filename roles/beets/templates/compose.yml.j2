services:
  beets:
    image: linuxserver/beets:2.8.0@sha256:eafa896e54703848deacce1d1fbe4bc7d0b831a93153fef4806ba0084407dbc1
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
