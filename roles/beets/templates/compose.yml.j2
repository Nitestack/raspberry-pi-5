services:
  beets:
    image: linuxserver/beets:2.9.0@sha256:98ae4d846d2e5e00f9d8f771288e4be9b963c0f1fb69003d599c470c435ccc76
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
