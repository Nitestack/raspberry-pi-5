services:
  beets:
    image: linuxserver/beets:2.11.0@sha256:59ac97d32e047ab7831fd73ef04bef9bc64026e528f61c27020458def88601f0
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
