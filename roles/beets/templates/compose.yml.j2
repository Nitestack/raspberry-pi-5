services:
  beets:
    image: linuxserver/beets:2.11.0@sha256:845de90ba2e3033c9e0aaa94cfc5542f8497f8a424331ea4389b6c4f0b44e5ca
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
