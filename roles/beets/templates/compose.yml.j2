services:
  beets:
    image: linuxserver/beets:2.10.0@sha256:1503dfbae2379b90db821de202ead77a269736f8cedde0b27f73e43c16f06801
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
