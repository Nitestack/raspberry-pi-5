services:
  beets:
    image: linuxserver/beets:2.7.1@sha256:58606b2408e23c1697815310a878d530e9c98c61d4ece317ffa9e9f11b234c1a
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
