services:
  beets:
    image: linuxserver/beets:2.8.0@sha256:f61a6c75d91a7a4a788f1e2e9c1fcd00e6b895b70739898616962905b20b1f74
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
