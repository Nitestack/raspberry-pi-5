services:
  beets:
    image: linuxserver/beets:2.11.0@sha256:31c423271ba038943ef374cfb5dc62931d3ad228e120705a80cf9454f7b19ad5
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
