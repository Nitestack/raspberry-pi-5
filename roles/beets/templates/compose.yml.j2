services:
  beets:
    image: linuxserver/beets:2.11.0@sha256:f8b58e60a3b07d5a2d0048aedcf83235d02babf7cb4dc579a92a767ffaca1aae
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
