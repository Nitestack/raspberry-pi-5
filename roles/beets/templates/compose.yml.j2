services:
  beets:
    image: linuxserver/beets:2.10.0@sha256:2958a54c962c41c1d1def64525fee246147b8d1feb2fa583526b04abd425be09
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
