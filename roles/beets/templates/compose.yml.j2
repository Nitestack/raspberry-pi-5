services:
  beets:
    image: linuxserver/beets:2.7.1@sha256:a31411b79a05a21f08ef7858d9e12996394070710cd215eab587e2024a11f011
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
