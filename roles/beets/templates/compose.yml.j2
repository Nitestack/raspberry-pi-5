services:
  beets:
    image: linuxserver/beets:2.10.0@sha256:49ba964b32ee7c44256619d5fda3db677072f21a92196846e81960b86604e1ad
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
