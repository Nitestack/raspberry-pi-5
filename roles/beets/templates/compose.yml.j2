services:
  beets:
    image: linuxserver/beets:2.11.0@sha256:58390a3cf44248ac0695dbe7f373ab2c37e12499ac707fc6005dfd6c6fa454ab
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
