services:
  beets:
    image: linuxserver/beets:2.7.1@sha256:bd70e0273428137bd1fef3d37efaf0998d66ad8a0feecff0b36bee1e75c10857
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
