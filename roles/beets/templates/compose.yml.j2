services:
  beets:
    image: linuxserver/beets:2.5.1@sha256:b848d21f79d1f38bf691d103f4c206f340b7b31f039bc4638cba4e07c4aa0729
    container_name: beets
    restart: always
    environment:
      PUID: 1000
      PGID: 1000
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
