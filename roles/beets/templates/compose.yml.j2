services:
  beets:
    image: linuxserver/beets:2.11.0@sha256:1fcd70a411df9735f76aef4c34e462e0b38f69e54a0f4923d337e5195560cbcf
    container_name: beets
    restart: always
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ beets_data_dir }}/config:/config"
      - "{{ music_library_dir }}:/music"
      - "{{ rdtclient_data_dir }}/downloads:/downloads"
