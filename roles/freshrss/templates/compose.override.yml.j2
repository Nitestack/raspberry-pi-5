# external-file
# owner: FreshRSS
# repo: FreshRSS
# path: Docker/freshrss/docker-compose.yml
# commit-hash: 50eeede063bb3d17f3129da1775df4dcf391a05f

services:
  freshrss:
    image: freshrss/freshrss:1.29.0@sha256:cca8988d05cd449e1c6c69405971b1e6fc2c2116ceeb45c9fa3fc33837997a75
    container_name: "{{ services.freshrss.container_name }}"
    restart: always
    networks:
      - caddy
    volumes:
      - "{{ freshrss_data_dir }}/data:/var/www/FreshRSS/data"
      - "{{ freshrss_data_dir }}/extensions:/var/www/FreshRSS/extensions"
    environment:
      TZ: "{{ timezone }}"
      CRON_MIN: "3,33"
      TRUSTED_PROXY: !reset null

networks:
  caddy:
    external: true
