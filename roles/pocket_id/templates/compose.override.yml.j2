# repo: pocket-id
# path: docker-compose.yml
# commit-hash: cd2e9f3a2ad753815ef8da998f9b54853d953a2a

services:
  pocket-id:
    image: ghcr.io/pocket-id/pocket-id:v2.8.0@sha256:04732e33c6c04ed97f521da026ef8c8ba47a59b25baec0d612d86a896674180f
    container_name: "{{ services.pocket_id.container_name }}"
    restart: always
    networks:
      - caddy
    env_file:
      - .env
      - .env.override
    ports: !reset []
    volumes:
      - "{{ pocket_id_data_dir }}/data:/app/data"

networks:
  caddy:
    external: true
