# commit-hash: cd2e9f3a2ad753815ef8da998f9b54853d953a2a

services:
  pocket-id:
    image: ghcr.io/pocket-id/pocket-id:v2.5.0@sha256:d2b6cf6735b8b50fc823506a0d107fa19a825797cc1d4268f7f6f325fb364a1f
    container_name: "{{ services.pocket_id.container_name }}"
    restart: always
    networks:
      - caddy
    env_file:
      - .env
      - .env.override
    ports: !reset []
    volumes:
      - "{{ pocket_id_data_dir }}/data:/app/data"

networks:
  caddy:
    external: true
