services:
  zerobyte:
    image: ghcr.io/nicotsx/zerobyte:v0.37.3@sha256:a855cf708df013b647022226cb6ecfe91aff39fb4574b2720ef36adb3d93aba4
    container_name: "{{ services.zerobyte.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      TZ: "{{ timezone }}"
      BASE_URL: "https://{{ services.zerobyte.domain }}"
      APP_SECRET: "{{ zerobyte_app_secret }}"
      TRUSTED_ORIGINS: "https://{{ services.pocket_id.domain }}"
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - "{{ zerobyte_data_dir }}/data:/var/lib/zerobyte"
      - "/root/.config/rclone:/root/.config/rclone"
      - "{{ backup_base_dir }}:{{ backup_base_dir }}"

networks:
  caddy:
    external: true
