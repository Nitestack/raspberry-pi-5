services:
  rdtclient:
    image: rogerfar/rdtclient:2.0.123@sha256:60ef5413d21f57b4821fd302cfc764f7538f06a6d4d2ec4d64129aba17387455
    container_name: "{{ services.rdtclient.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ rdtclient_data_dir }}/db:/data/db"
      - "{{ rdtclient_data_dir }}/downloads:/data/downloads"

networks:
  caddy:
    external: true
