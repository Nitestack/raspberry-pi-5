services:
  rdtclient:
    image: rogerfar/rdtclient:2.0.140@sha256:3f5f37783da704d50bcc6773ffa22eaed86fd4bfbd225a7929e181c6774ead29
    container_name: "{{ services.rdtclient.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ rdtclient_data_dir }}/db:/data/db"
      - "{{ rdtclient_data_dir }}/downloads:/data/downloads"

networks:
  caddy:
    external: true
