services:
  rdtclient:
    image: rogerfar/rdtclient:2.0.129@sha256:ecfe57e425dbb14ea9dcf5bb41e05cca6e0127c330367438bc1bc466a5290329
    container_name: "{{ services.rdtclient.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ rdtclient_data_dir }}/db:/data/db"
      - "{{ rdtclient_data_dir }}/downloads:/data/downloads"

networks:
  caddy:
    external: true
