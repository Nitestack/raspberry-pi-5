services:
  rdtclient:
    image: rogerfar/rdtclient:2.0.136@sha256:a05f0427946a4c3c64dc9d556c017f9a181acec320ecf218b6334a1066c11d1f
    container_name: "{{ services.rdtclient.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ rdtclient_data_dir }}/db:/data/db"
      - "{{ rdtclient_data_dir }}/downloads:/data/downloads"

networks:
  caddy:
    external: true
