services:
  rdtclient:
    image: rogerfar/rdtclient:2.0.125@sha256:d074c55ea0d4a9e8c3bd26e6e34151bdd339822be2db72b568c52c098b1afee7
    container_name: "{{ services.rdtclient.container_name }}"
    restart: always
    networks:
      - caddy
    environment:
      PUID: "{{ ansible_user_uid }}"
      PGID: "{{ ansible_user_gid }}"
      TZ: "{{ timezone }}"
    volumes:
      - "{{ rdtclient_data_dir }}/db:/data/db"
      - "{{ rdtclient_data_dir }}/downloads:/data/downloads"

networks:
  caddy:
    external: true
